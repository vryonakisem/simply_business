SELECT 
    TRADE,
    COUNT(*) AS total_forms,
    SUM(CASE WHEN NUMBER_OF_QUOTES = 0 THEN 1 ELSE 0 END) AS referred,
    ROUND(SUM(CASE WHEN NUMBER_OF_QUOTES = 0 THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 1) AS referral_pct
FROM form_submissions
WHERE TRADE IS NOT NULL
GROUP BY TRADE
HAVING COUNT(*) > 30
ORDER BY referral_pct DESC
LIMIT 15;
