SELECT 
    t.PAYMENT_METHOD,
    t.TRANSACTION_REASON,
    COUNT(*) AS cancellations,
    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (PARTITION BY t.PAYMENT_METHOD), 1) AS pct_within_method
FROM policy_transaction_data t
WHERE TRANSACTION_TYPE = 'Cancellation'
    AND PAYMENT_METHOD IS NOT NULL
GROUP BY t.PAYMENT_METHOD, t.TRANSACTION_REASON
ORDER BY t.PAYMENT_METHOD, cancellations DESC;
